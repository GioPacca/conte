PORT=3000

# Cadenas de conexión a PostgreSQL en Supabase.
# Obtenerlas en: Supabase → tu proyecto → Connect → ORM → Prisma.

# Runtime de la app: pooler en modo transacción (puerto 6543)
DATABASE_URL="postgresql://usuario:password@host:6543/postgres?pgbouncer=true"

# Migraciones (prisma migrate): pooler en modo sesión (puerto 5432)
DIRECT_URL="postgresql://usuario:password@host:5432/postgres"

# Secreto para firmar las cookies de sesión. Generar uno aleatorio con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="cambiar-por-un-secreto-aleatorio"

# En producción (Render) definir NODE_ENV=production:
# activa trust proxy y la cookie de sesión pasa a secure (solo HTTPS).
# NODE_ENV="production"
